# ════════════════════════════════════════════════════════════════════════════
#  LIDDIS — Variáveis de Ambiente
#  Copie este arquivo para .env e preencha os valores
#  NUNCA faça commit do arquivo .env (já está no .gitignore)
# ════════════════════════════════════════════════════════════════════════════

# ── Django ────────────────────────────────────────────────────────────────────
# Gere com: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=troque-por-uma-chave-longa-e-aleatoria

# True em desenvolvimento, False em produção
DEBUG=False

# Seu domínio em produção (sem https://)
ALLOWED_HOSTS=seudominio.com,www.seudominio.com

# ── Banco de Dados — PostgreSQL ────────────────────────────────────────────────
# USE_SQLITE=True apenas para desenvolvimento local sem PostgreSQL
USE_SQLITE=False

DB_NAME=liddis_db
DB_USER=postgres
DB_PASSWORD=senha-forte-aqui
DB_HOST=localhost
DB_PORT=5432

# ── E-mail ─────────────────────────────────────────────────────────────────────
# Opções: console | resend | sendgrid | gmail | smtp
EMAIL_PROVIDER=resend

# ── Opção 1: Resend (recomendado — 3.000 e-mails/mês grátis)
# Crie conta em https://resend.com → API Keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx

# ── Opção 2: SendGrid (100 e-mails/dia grátis)
# Crie conta em https://sendgrid.com → Settings → API Keys
# SENDGRID_API_KEY=SG.xxxxxxxxxxxxxxxxxxxx

# ── Opção 3: Gmail (500/dia — precisa de App Password, não a senha normal)
# Google Account → Security → 2-Step Verification → App passwords
# GMAIL_USER=seu@gmail.com
# GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx

# Remetente padrão — deve ser um domínio verificado no seu provedor
DEFAULT_FROM_EMAIL=LIDDIS <noreply@seudominio.com>

# ── SMS via Twilio (opcional — verificação por celular) ────────────────────────
# Crie conta em https://twilio.com → Console → Account Info
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_PHONE_NUMBER=+5511999999999

# ── Monitoramento de Erros — Sentry (recomendado em produção) ─────────────────
# Crie conta em https://sentry.io → Projects → Django → DSN
SENTRY_DSN=https://xxxxxxxxxx@oXXXXXX.ingest.sentry.io/XXXXXXX

# ── CORS (frontend React/Next.js) ─────────────────────────────────────────────
CORS_ORIGINS=https://seudominio.com,https://www.seudominio.com

# ── CSRF Trusted Origins ───────────────────────────────────────────────────────
# Obrigatório em produção — deve incluir o protocolo (https://)
CSRF_TRUSTED_ORIGINS=https://seudominio.com,https://www.seudominio.com

# ── JWT ────────────────────────────────────────────────────────────────────────
JWT_ACCESS_MINUTES=60
JWT_REFRESH_DAYS=7

# ── Google OAuth — django-allauth ──────────────────────────────────────────────
# PASSO A PASSO para obter as credenciais:
#
# 1. Acesse https://console.cloud.google.com
# 2. Crie um projeto (ou selecione o existente)
# 3. Menu → APIs & Services → OAuth consent screen
#    - User Type: External → Create
#    - Preencha nome do app, e-mail de suporte, e-mail do desenvolvedor
#    - Salve e continue (pode deixar Scopes e Test users em branco por ora)
# 4. Menu → APIs & Services → Credentials → Create Credentials → OAuth client ID
#    - Application type: Web application
#    - Nome: LIDDIS (ou qualquer nome)
#    - Authorized redirect URIs:
#        Desenvolvimento: http://localhost:8000/accounts/google/login/callback/
#        Produção:        https://seudominio.com/accounts/google/login/callback/
# 5. Copie o Client ID e o Client Secret abaixo
# 6. Após configurar, rode: python manage.py migrate
#    (allauth cria a tabela SocialApp no banco — veja INSTRUCOES_GOOGLE_OAUTH.md)
#
GOOGLE_CLIENT_ID=xxxxxxxxxxxx-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx.apps.googleusercontent.com
GOOGLE_SECRET=GOCSPX-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
