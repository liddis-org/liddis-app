# ════════════════════════════════════════════════════════════════════════════
#  LIDDIS — Variáveis de Ambiente
#  Copie este arquivo para .env e preencha os valores
#  NUNCA faça commit do arquivo .env (já está no .gitignore)
#
#  Stack de produção:
#    Backend  → Google Cloud Run  (Docker)
#    Banco    → Supabase          (PostgreSQL)
#    Auth     → Google OAuth      (django-allauth)
# ════════════════════════════════════════════════════════════════════════════

# ── Django ────────────────────────────────────────────────────────────────────
# Gere com: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=troque-por-uma-chave-longa-e-aleatoria

# True em desenvolvimento, False em produção
DEBUG=False

# Domínio Cloud Run + domínio customizado
ALLOWED_HOSTS=liddis.com.br,www.liddis.com.br,SEU-SERVICO.a.run.app,localhost,127.0.0.1

# ── Banco de Dados — Supabase (PostgreSQL) ────────────────────────────────────
# Supabase → Project Settings → Database → Connection string → URI
# Use a Connection Pooler (porta 6543) — recomendado para Cloud Run
# Formato: postgresql://postgres.[ref]:[senha]@aws-0-[região].pooler.supabase.com:6543/postgres
DATABASE_URL=postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres

# USE_SQLITE=True apenas para desenvolvimento local sem Docker/PostgreSQL
USE_SQLITE=False

# ── E-mail ─────────────────────────────────────────────────────────────────────
# Opções: console | resend | sendgrid | gmail | smtp
EMAIL_PROVIDER=resend

# ── Opção 1: Resend (recomendado — 3.000 e-mails/mês grátis)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx

# ── Opção 2: SendGrid (100 e-mails/dia grátis)
# SENDGRID_API_KEY=SG.xxxxxxxxxxxxxxxxxxxx

# ── Opção 3: Gmail (App Password — não a senha normal)
# GMAIL_USER=seu@gmail.com
# GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx

# Remetente padrão — deve ser domínio verificado no provedor de e-mail
DEFAULT_FROM_EMAIL=LIDDIS <noreply@liddis.com.br>

# ── CSRF e CORS ────────────────────────────────────────────────────────────────
# Inclua o protocolo (https://)
CSRF_TRUSTED_ORIGINS=https://liddis.com.br,https://www.liddis.com.br,https://SEU-SERVICO.a.run.app

# Frontend React/Next.js separado (se houver):
# CORS_ORIGINS=https://liddis.com.br,https://www.liddis.com.br

# ── JWT ────────────────────────────────────────────────────────────────────────
JWT_ACCESS_MINUTES=60
JWT_REFRESH_DAYS=7

# ── Google OAuth — django-allauth ──────────────────────────────────────────────
# Google Cloud Console → APIs & Services → Credentials → OAuth 2.0 Client IDs
#
# URIs de redirecionamento autorizados:
#   Desenvolvimento: http://localhost:8000/accounts/google/login/callback/
#   Produção:        https://liddis.com.br/accounts/google/login/callback/
#                    https://www.liddis.com.br/accounts/google/login/callback/
#                    https://SEU-SERVICO.a.run.app/accounts/google/login/callback/
#
GOOGLE_CLIENT_ID=xxxxxxxxxxxx-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx.apps.googleusercontent.com
GOOGLE_SECRET=GOCSPX-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Site ──────────────────────────────────────────────────────────────────────
SITE_DOMAIN=liddis.com.br
SITE_NAME=LIDDIS

# ── Google Cloud Storage (uploads em produção) ────────────────────────────────
# Cloud Run tem filesystem efêmero — obrigatório para uploads
GCS_BUCKET_NAME=liddis-uploads-prod

# ── Monitoramento — Sentry (recomendado em produção) ──────────────────────────
# SENTRY_DSN=https://xxxxxxxxxx@oXXXXXX.ingest.sentry.io/XXXXXXX

# ── SMS via Twilio (opcional) ─────────────────────────────────────────────────
# TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# TWILIO_PHONE_NUMBER=+5511999999999

# ── WhatsApp ──────────────────────────────────────────────────────────────────
# Número de vendas — para onde o usuário é direcionado ao clicar em um plano pago.
# Formato internacional SEM '+' e SEM espaços. Ex: 5511999999999
WHATSAPP_SALES_NUMBER=5511999999999

# WhatsApp Business Cloud API — notifica o admin quando alguém clica em plano pago.
# Configure em: developers.facebook.com → seu App → WhatsApp → API Setup
#
# Passo a passo rápido:
#   1. Crie uma conta em business.facebook.com
#   2. Crie um App do tipo "Business" em developers.facebook.com
#   3. Adicione o produto "WhatsApp" ao App
#   4. Em "API Setup", copie o "Temporary access token" (válido 24h) ou gere um permanente
#   5. Copie o "Phone number ID" (não é o número em si — é um ID numérico)
#   6. WHATSAPP_ADMIN_NUMBER = seu número pessoal que receberá as notificações (formato: 5511999999999)
#   7. Para produção: gere um System User Token permanente em business.facebook.com → System Users
#
# Obs: A notificação de texto funciona se o admin tiver enviado uma mensagem para o número
# comercial nas últimas 24h. Para notificações sem essa restrição, crie um template aprovado pela Meta.
WHATSAPP_API_TOKEN=EAAxxxxxxxxxxxxxxxx
WHATSAPP_PHONE_NUMBER_ID=1234567890123456
WHATSAPP_ADMIN_NUMBER=5511999999999
