# ════════════════════════════════════════════════════════════════════════════
#  LIDDIS — Variáveis de Ambiente — PRODUÇÃO
#  Domínio: https://liddis.com.br
#  Hospedagem: Railway.app (backend) + Supabase (banco) + GCS (uploads)
#
#  1. Copie este arquivo: cp .env.production.example .env
#  2. Preencha TODOS os valores marcados com <PREENCHA>
#  3. NUNCA faça commit do arquivo .env
# ════════════════════════════════════════════════════════════════════════════

# ── Django ────────────────────────────────────────────────────────────────────
# Gere com: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=<PREENCHA_CHAVE_FORTE_40_CHARS_MINIMO>

DEBUG=False

# Railway injeta o domínio automaticamente; adicione também o domínio customizado
ALLOWED_HOSTS=liddis.com.br,www.liddis.com.br,<SEU_APP>.up.railway.app

# ── Banco de Dados — Supabase (PostgreSQL) ────────────────────────────────────
# Supabase → Project Settings → Database → Connection Pooler → URI (porta 6543)
DATABASE_URL=postgresql://postgres.<PROJECT-REF>:<PASSWORD>@aws-0-sa-east-1.pooler.supabase.com:6543/postgres

# ── E-mail ─────────────────────────────────────────────────────────────────────
EMAIL_PROVIDER=resend

# Resend: https://resend.com → API Keys → Create API Key
# Verificar domínio liddis.com.br em: Resend → Domains → Add Domain
RESEND_API_KEY=re_<PREENCHA>

# Remetente — use o domínio verificado no Resend
DEFAULT_FROM_EMAIL=LIDDIS <noreply@liddis.com.br>

# ── CSRF e CORS ────────────────────────────────────────────────────────────────
CSRF_TRUSTED_ORIGINS=https://liddis.com.br,https://www.liddis.com.br,https://<SEU_APP>.up.railway.app

# Se houver frontend separado (Vercel, etc.), adicione aqui:
# CORS_ORIGINS=https://liddis.com.br,https://www.liddis.com.br

# ── JWT ────────────────────────────────────────────────────────────────────────
JWT_ACCESS_MINUTES=60
JWT_REFRESH_DAYS=7

# ── Site (Sites Framework + allauth) ──────────────────────────────────────────
SITE_DOMAIN=liddis.com.br
SITE_NAME=LIDDIS

# ── Google OAuth — django-allauth ──────────────────────────────────────────────
# Google Cloud Console → APIs & Services → Credentials → OAuth 2.0 Client IDs
# URIs de redirecionamento autorizados:
#   https://liddis.com.br/accounts/google/login/callback/
#   https://www.liddis.com.br/accounts/google/login/callback/
GOOGLE_CLIENT_ID=<PREENCHA>.apps.googleusercontent.com
GOOGLE_SECRET=GOCSPX-<PREENCHA>

# ── Google Cloud Storage — uploads de arquivos ────────────────────────────────
# GCS → Create Bucket → nome sugerido: liddis-media-prod
# Service Account com roles: Storage Object Admin
GCS_BUCKET_NAME=liddis-media-prod
# Em Railway: adicionar GOOGLE_APPLICATION_CREDENTIALS_JSON com conteúdo do JSON da SA

# ── Monitoramento — Sentry ─────────────────────────────────────────────────────
# https://sentry.io → New Project → Django
SENTRY_DSN=https://<PREENCHA>@o<ID>.ingest.sentry.io/<PROJECT_ID>

# ── SMS via Twilio (opcional) ─────────────────────────────────────────────────
# TWILIO_ACCOUNT_SID=AC<PREENCHA>
# TWILIO_AUTH_TOKEN=<PREENCHA>
# TWILIO_PHONE_NUMBER=+55119<PREENCHA>

# ── IA — OpenAI (LUMI) ────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-proj-<PREENCHA>
