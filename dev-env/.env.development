# ════════════════════════════════════════════════════════════════════════════
#  LIDDIS — Ambiente de DESENVOLVIMENTO LOCAL
#  Copie este arquivo para o projeto raiz como .env ao desenvolver
#  Comando: copy dev-env\.env.development .env   (Windows)
#           cp dev-env/.env.development .env      (Linux/Mac)
# ════════════════════════════════════════════════════════════════════════════

# ── Django ────────────────────────────────────────────────────────────────────
SECRET_KEY=dev-secret-key-somente-para-desenvolvimento-local-12345678901234567890
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0

# ── Banco de Dados ────────────────────────────────────────────────────────────
# SQLite é suficiente para desenvolvimento — não precisa do PostgreSQL instalado
USE_SQLITE=True
# DATABASE_URL=          ← descomente e preencha para testar com Supabase em dev

# ── Modo Teste (aceita qualquer senha — NUNCA em produção) ───────────────────
TEST_MODE=True

# ── E-mail (console = imprime no terminal, não envia de verdade) ─────────────
EMAIL_PROVIDER=console

# ── Google OAuth (não obrigatório em dev com TEST_MODE=True) ─────────────────
# GOOGLE_CLIENT_ID=      ← preencha apenas se testar OAuth em dev
# GOOGLE_SECRET=

# ── JWT ────────────────────────────────────────────────────────────────────────
JWT_ACCESS_MINUTES=60
JWT_REFRESH_DAYS=7

# ── CORS — permite frontend local (React/Vue em porta diferente) ───────────────
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ── CSRF ──────────────────────────────────────────────────────────────────────
CSRF_TRUSTED_ORIGINS=http://localhost:8000,http://127.0.0.1:8000

# ── Site ──────────────────────────────────────────────────────────────────────
SITE_DOMAIN=localhost:8000
SITE_NAME=LIDDIS DEV
